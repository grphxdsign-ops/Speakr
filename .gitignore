# Python environment
.venv/
.venv-train/
.venv-gguf/
__pycache__/
*.pyc

# LoRA fine-tune experiment artifacts (training/*.py scripts are kept and
# committed; generated datasets, checkpoints, and exported models are not --
# multi-GB and fully reproducible by re-running the scripts).
training/*.jsonl
training/adapter/
training/adapter_final/
training/merged/
training/gguf/
training/smoke_out/

# Machine-specific / regenerated on first run.
# config.json is excluded on purpose so each machine gets its own defaults
# (e.g. the Mac generates a config with the fn hotkey instead of Right Ctrl).
config.json
speakr.log
.speakr.lock
panel.url
show.request

# Personal data — never publish. Both regenerate empty on first run.
# Copy them between your own machines by hand if you want them to follow you.
dictionary.txt
learned_words.json

# Build output
dist/
build/
*.spec
icon.ico

# Editor / tooling
.claude/
.DS_Store
Thumbs.db

# Test scratch files
scripts/_*.json
scripts/_*.txt
