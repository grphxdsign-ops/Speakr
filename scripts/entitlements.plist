<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Hardened-runtime entitlements for the Developer ID signed Speakr.app
     (release.yml mac-dmg job). The three cs.* exceptions are the standard
     set a PyInstaller-frozen Python app needs to run at all under the
     hardened runtime (ctypes/cffi and the bundled ML dylibs); audio-input
     is required for the microphone once the runtime is hardened. -->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
